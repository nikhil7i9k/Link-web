    const urlRegex = /https?:\/\/[^\s,\n]+/g;
    return [...new Set(text.match(urlRegex) || [])];
  };

  const handleAdd = () => {
    const found = parseLinks(input);
    if (!found.length) return;
    const newLinks = found.map((url) => ({
      url,
      platform: detectPlatform(url),
      id: Math.random().toString(36).slice(2),
    }));
    setLinks((prev) => [...prev, ...newLinks.filter(n => !prev.find(p => p.url === n.url))]);
    setInput("");
    setFlash(true);
    setTimeout(() => setFlash(false), 500);
  };

  const openAll = () => links.forEach(l => window.open(l.url, "_blank"));
  const openSelected = (platform) => links.filter(l => l.platform?.id === platform).forEach(l => window.open(l.url, "_blank"));
  const removeLink = (id) => setLinks(prev => prev.filter(l => l.id !== id));
  const clearAll = () => setLinks([]);

  const grouped = PLATFORMS.map(p => ({
    ...p,
    items: links.filter(l => l.platform?.id === p.id),
  })).filter(p => p.items.length > 0);

