import { useState } from "react";

const PLATFORMS = [
  { id: "terabox", name: "Terabox", icon: "📦", color: "#00f5ff", pattern: /terabox\.com|1024terabox\.com/i },
  { id: "diskwala", name: "Diskwala", icon: "💾", color: "#ff00ff", pattern: /diskwala\.com/i },
  { id: "instagram", name: "Instagram", icon: "📸", color: "#ff6b9d", pattern: /instagram\.com|instagr\.am/i },
  { id: "youtube", name: "YouTube", icon: "▶", color: "#ff3c3c", pattern: /youtube\.com|youtu\.be/i },
  { id: "twitter", name: "Twitter/X", icon: "✕", color: "#1d9bf0", pattern: /twitter\.com|x\.com/i },
  { id: "facebook", name: "Facebook", icon: "f", color: "#4267B2", pattern: /facebook\.com|fb\.com|fb\.watch/i },
];

function detectPlatform(url) {
  for (const p of PLATFORMS) {
    if (p.pattern.test(url)) return p;
  }
  return null;
}

function GlitchText({ text }) {
  return (
    <span className="glitch" data-text={text} style={{ position: "relative" }}>
      {text}
    </span>
  );
}

export default function ZoomLink() {
  const [input, setInput] = useState("");
